{
  "name": "@stellar-zklogin/sdk",
  "version": "2.1.0",
  "description": "World's best zkLogin SDK for Stellar - Replace wallets with social login in 3 lines",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts src/react/index.ts src/core/index.ts --format cjs,esm --dts --external react --minify",
    "dev": "tsup src/index.ts src/react/index.ts src/core/index.ts --format cjs,esm --dts --external react --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "stellar",
    "zklogin",
    "zk-proofs",
    "groth16",
    "oauth",
    "wallet",
    "x402",
    "xray-protocol",
    "bn254",
    "poseidon",
    "soroban",
    "embedded-wallet",
    "web3",
    "blockchain",
    "authentication",
    "social-login",
    "google-login",
    "apple-login",
    "zero-knowledge"
  ],
  "author": "Stellar zkLogin Gateway",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stellar-zklogin/sdk"
  },
  "homepage": "https://stellargateway.vercel.app",
  "bugs": {
    "url": "https://github.com/stellar-zklogin/sdk/issues"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^12.0.0",
    "snarkjs": "^0.7.0",
    "jose": "^5.0.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "poseidon-lite": "^0.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.55.0",
    "react": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.mjs",
      "require": "./dist/react/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.mjs",
      "require": "./dist/core/index.js"
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  }
}
