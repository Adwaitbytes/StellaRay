# Environment Variables Template
# Copy this to .env.local for development

# Neon Database (for waitlist)
# Get your connection string from: https://neon.tech
DATABASE_URL=postgresql://username:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-secret-here

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-generated-secret-here

# Public Variables (exposed to browser)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_FRIENDBOT_URL=https://friendbot.stellar.org
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ZK Login Services
# For demo, these use the local API routes. For production, use dedicated services.
NEXT_PUBLIC_PROVER_URL=/api/zk/prove
NEXT_PUBLIC_SALT_SERVICE_URL=/api/zk/salt

# Salt Service Secret (used for deriving user salts)
# Generate with: openssl rand -hex 32
SALT_DERIVATION_SECRET=your-secret-salt-key-here

# Soroban Contracts (Testnet - deployed)
NEXT_PUBLIC_ZK_VERIFIER_CONTRACT_ID=CDAQXHNK2HZJJE6EDJAO3AWM6XQSM4C3IRB5R3AJSKFDRK4BZ77PACP6
NEXT_PUBLIC_SMART_WALLET_WASM_HASH=2a7e72543da92134de77821c920b82e6c5fb7cd02b5283cfeb87deb894e14d5d
NEXT_PUBLIC_GATEWAY_FACTORY_CONTRACT_ID=CAAOQR7L5UVV7CZVYDS5IU72JKAUIEUBLTVLYGTBGBENULLNM3ZJIF76
NEXT_PUBLIC_JWK_REGISTRY_CONTRACT_ID=CAMO5LYOANZWUZGJYNEBOAQ6SAQKQO3WBLTDBJ6VAGYNMBOIUOVXGS2I
NEXT_PUBLIC_X402_FACILITATOR_CONTRACT_ID=CDJMT4P4DUZVRRLTF7Z3WCXK6YJ57PVB6K7FUCGW7ZOI5LDFAWBWTTZZ

# Network Configuration
NEXT_PUBLIC_DEFAULT_NETWORK=testnet
